# Node (packages/js)
node_modules/
*.log
*.tgz
*.tsbuildinfo
.tsup/
docs/.vitepress/cache/
docs/.vitepress/dist/

# packages/r3f: bundler-consumed React lib — dist is published via prepublishOnly, not
# committed (unlike packages/js/dist, which the CDN needs). Lockfile omitted at 0.1.0 (CI
# uses npm install; see ci.yml).
packages/r3f/dist/
packages/r3f/package-lock.json

# packages/gpu: framework-agnostic WebGL2 lib — same policy as r3f (dist published via
# prepublishOnly, lockfile omitted at 0.1.0; CI uses npm install; see ci.yml).
packages/gpu/dist/
packages/gpu/package-lock.json

# Python (packages/python, packages/shaders)
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
build/
dist-python/
.eggs/

# Rust (packages/rust)
# Library crates: keep lockfiles out. (Inline comments aren't valid in .gitignore — the pattern
# must be on its own line, or it silently matches nothing.)
target/
Cargo.lock

# WASM (packages/wasm): pkg/ is the wasm-pack build output, regenerated by CI / build.
packages/wasm/pkg/

# OS / editors
.DS_Store
.vscode/
.idea/
.claude/

# NOTE: packages/js/dist IS committed on purpose (CDN + demos need it without a build).
# It is force-added in that package; do not add a blanket dist/ ignore here.
