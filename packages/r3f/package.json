{
  "name": "helix-noise-r3f",
  "version": "0.1.0",
  "description": "react-three-fiber components for Helix Noise — declarative divergence-free flow fields (particles, materials) driven by the helix-noise core.",
  "keywords": [
    "helix-noise",
    "react-three-fiber",
    "r3f",
    "three",
    "flow-field",
    "curl-noise",
    "divergence-free",
    "particles",
    "vfx",
    "generative-art"
  ],
  "author": "Rifat Jumagulov <jum.rifm@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "check": "npm run typecheck && npm run test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "helix-noise": "file:../js"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=8",
    "react": ">=18",
    "three": ">=0.150"
  },
  "devDependencies": {
    "@react-three/fiber": "^8.17.0",
    "@types/react": "^18.3.0",
    "@types/three": "^0.160.0",
    "react": "^18.3.0",
    "three": "^0.160.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rifmj/helix-noise.git",
    "directory": "packages/r3f"
  },
  "homepage": "https://github.com/rifmj/helix-noise#readme",
  "bugs": {
    "url": "https://github.com/rifmj/helix-noise/issues"
  }
}
